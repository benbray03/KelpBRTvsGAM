geom_point(alpha = 0.5) +
scale_color_viridis_c(direction = -1) +
facet_wrap(~ period, ncol = 1) +
labs(title = "Mean predicted log kelp density by 25-year period (BRT)",
color = "log kelp density") +
theme_minimal() +
