# Plot observed vs predicted
ggplot(giant_ci_test, aes(x = macpyr_log, y = pred_gam)) +
geom_point(alpha = 0.4, color = "steelblue") +
geom_abline(slope = 1, intercept = 0, linetype = "dashed", color = "red") +
labs(x = "Observed (log kelp density)",
