comparison_hist_near <- bind_rows(giant_ci_historical, giant_ci_near)
# Function to assign tertile categories
assign_tertiles <- function(df) {
tertiles <- quantile(df$macpyr_log, probs = c(1/3, 2/3), na.rm = TRUE)
df |>
mutate(category = case_when(
macpyr_log <= tertiles[1] ~ "Low",
macpyr_log <= tertiles[2] ~ "Medium",
macpyr_log > tertiles[2] ~ "High"
)) |>
mutate(category = factor(category, levels = c("Low", "Medium", "High")))
}
# Apply tertiles within each period separately
giant_ci_categorized <- giant_ci_pred_periods |>
group_by(period) |>
group_modify(~ assign_tertiles(.x)) |>
ungroup()
# Scatter plot grouped by category
ggplot(giant_ci_categorized, aes(x = longitude, y = latitude, color = category)) +
geom_point(alpha = 0.5) +
scale_color_manual(values = c("Low" = "red3", "Medium" = "orange2", "High" = "steelblue")) +
facet_wrap(~ period, ncol = 2) +
labs(x = "Longitude", y = "Latitude",
color = "Kelp density",
title = "Predicted kelp density by period - Channel Islands") +
theme_classic()
# Get tertile thresholds from historical period
historical_tertiles <- quantile(giant_ci_historical$macpyr_log,
probs = c(1/3, 2/3), na.rm = TRUE)
near_tertiles <- quantile(giant_ci_near$macpyr_log,
probs = c(1/3, 2/3), na.rm = TRUE)
# Join historical and near future by location
scatter_comparison <- giant_ci_historical |>
rename(macpyr_log_hist = macpyr_log) |>
inner_join(
giant_ci_near |> rename(macpyr_log_near = macpyr_log),
by = c("latitude", "longitude")
)
# Plot
ggplot(scatter_comparison, aes(x = macpyr_log_hist, y = macpyr_log_near)) +
geom_point(alpha = 0.4, color = "steelblue") +
# Historical tertile thresholds (vertical lines)
geom_vline(xintercept = historical_tertiles[1], linetype = "dashed", color = "red3") +
geom_vline(xintercept = historical_tertiles[2], linetype = "dashed", color = "orange2") +
# Near future tertile thresholds (horizontal lines)
geom_hline(yintercept = near_tertiles[1], linetype = "dashed", color = "red3") +
geom_hline(yintercept = near_tertiles[2], linetype = "dashed", color = "orange2") +
# 1:1 line
geom_abline(slope = 1, intercept = 0, linetype = "solid", color = "grey50") +
labs(x = "Historical (2001-2025) mean log kelp density",
y = "Near future (2026-2050) mean log kelp density",
title = "Historical vs Near Future kelp density - Channel Islands") +
theme_classic()
