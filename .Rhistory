scale_x_continuous(limits = axis_range) +
scale_y_continuous(limits = axis_range) +
coord_fixed() +
labs(title = "GAM vs BRT Site-Level Mean Predictions",
x = "GAM Mean Prediction (log)", y = "BRT Mean Prediction (log)") +
theme_bw()
