library(readr)
library(ggplot2)
library(tidyverse)
giant_ci_pred <- read_csv("csv/brt_predictions/giant_se_historical_predictions_300res_ci.csv")
# plot each of the points on a map
ggplot(giant_ci_pred, aes(x = longitude, y = latitude, color = macpyr_log)) +
geom_point(alpha = 0.5) +
scale_color_viridis_c() +
labs(title = "Predicted log kelp density (historical)") +
theme_minimal()
View(historical)
